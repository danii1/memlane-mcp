{
  "name": "@memlane/mcp",
  "version": "0.1.1",
  "description": "MCP server for Memlane: search, capture, and manage your saved links and notes",
  "type": "module",
  "bin": {
    "memlane-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "memlane",
    "model-context-protocol",
    "second-brain",
    "bookmarks",
    "notes"
  ],
  "homepage": "https://memlane.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danii1/memlane-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/danii1/memlane-mcp/issues"
  },
  "author": "Daniil Pokrovsky",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "~6.0.2"
  }
}
